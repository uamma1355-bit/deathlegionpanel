    {
      "source": "/admin/applications",
      "destination": "/api/applications-page"
    },
    {
      "source": "/(.*)",
      "destination": "/api/proxy"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/auto-start",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/credits?action=reset",
      "schedule": "0 0 * * *"
    }
  ]
}