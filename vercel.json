{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "cd shared && npm install --no-audit --no-fund && cd ../frontend && npm install --legacy-peer-deps --no-audit --no-fund && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo 'install handled in buildCommand'",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://8000-210e4afe-d6d5-4cc1-b3d3-05f40077ea15.daytonaproxy01.eu/api/:path*" },
    { "source": "/sanctum/:path*", "destination": "https://8000-210e4afe-d6d5-4cc1-b3d3-05f40077ea15.daytonaproxy01.eu/sanctum/:path*" },
    { "source": "/((?!api/|sanctum/|admin/|assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
