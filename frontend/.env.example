# Frontend environment variables
# Copy this to .env.local for development.

# The base URL of the decoupled Pterodactyl backend (Laravel API).
# In dev, set this to your local backend (e.g. http://127.0.0.1:8000).
# In prod, set this to your API host (e.g. https://api.example.com).
VITE_API_URL=http://127.0.0.1:8000

# Authentication mode:
#   cookie  - Sanctum SPA mode (default). Requires VITE_API_URL to share a root
#             domain with the frontend OR CORS+SANCTUM_STATEFUL_DOMAINS to be
#             configured on the backend for the frontend origin.
#   token   - Bearer token mode (opt-in). User pastes a `ptlc_` API key into
#             the UI; frontend stores it in localStorage and sends as
#             `Authorization: Bearer ptlc_...`. Useful for cross-domain Vercel
#             preview deployments.
VITE_AUTH_MODE=cookie

# App display name (shown in <title>, login screen, etc.)
VITE_APP_NAME=Pterodactyl

# (Optional) Sentry DSN for production error reporting.
# VITE_SENTRY_DSN=

# (Optional) reCAPTCHA site key for the login form, if enabled on the backend.
# VITE_RECAPTCHA_SITE_KEY=
